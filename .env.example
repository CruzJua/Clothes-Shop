# ============================================================
#  .env.example — copy this file to .env and fill in values
#  NEVER commit your real .env to version control
# ============================================================

# MongoDB connection string (Atlas or local)
# Get it from: https://cloud.mongodb.com/ → Connect → Drivers
CONNECTION_STRING="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>"

# Express session secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-a-long-random-secret"

# Single-admin credentials — set these in your environment, never commit real values
# The login route compares against these using a timing-safe comparison
ADMIN_USER="admin"
ADMIN_PASS="replace-with-a-strong-password"

# Cloudinary credentials — get from: https://console.cloudinary.com/ → Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Server port (optional — defaults to 3050)
# PORT=3050

# Set to "production" when deployed (enables HTTPS-only cookies)
# NODE_ENV=production
